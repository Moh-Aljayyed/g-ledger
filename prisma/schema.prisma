generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum Sector {
  INDUSTRIAL
  COMMERCIAL
  SERVICES
  BANKING
  INSURANCE
  REAL_ESTATE
  CONTRACTING
  AGRICULTURAL
  TECHNOLOGY
  NON_PROFIT
  CROWDFUNDING
  MEDICAL_HOSPITAL
  MEDICAL_PHARMACY
  MEDICAL_CLINIC
  MEDICAL_LAB
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
  SUPER_ADMIN
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountNature {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

// ============ MULTI-TENANCY ============

model Tenant {
  id              String   @id @default(cuid())
  name            String
  sector          Sector
  country         String   @default("SA") // ISO country code
  locale          String   @default("ar")
  currency        String   @default("SAR")
  vatRate         Decimal  @default(15) @db.Decimal(5, 2)
  registrationNumber String? // السجل التجاري / الرقم الضريبي
  fiscalYearStart Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users          User[]
  accounts       Account[]
  journalEntries JournalEntry[]
  fiscalPeriods  FiscalPeriod[]
  invoices       Invoice[]
  taxConfig      TaxConfig?
  customers      Customer[]
  vendors        Vendor[]
  bills          Bill[]
  payments       Payment[]
  employees      Employee[]
  payrolls       Payroll[]
  bankAccounts   BankAccount[]
  bankTransactions BankTransaction[]
  subscription   Subscription?
  products      Product[]
  stockMovements StockMovement[]
  fixedAssets   FixedAsset[]
  depreciationEntries DepreciationEntry[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ACCOUNTANT)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// ============ CHART OF ACCOUNTS ============

model Account {
  id        String        @id @default(cuid())
  code      String
  nameAr    String
  nameEn    String
  type      AccountType
  nature    AccountNature
  parentId  String?
  parent    Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children  Account[]     @relation("AccountTree")
  level     Int
  isLeaf    Boolean       @default(true)
  isSystem  Boolean       @default(false)
  isActive  Boolean       @default(true)
  sectorTag String?
  metadata  Json?
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
}

// ============ FISCAL PERIODS ============

model FiscalPeriod {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  journalEntries JournalEntry[]

  @@unique([tenantId, startDate, endDate])
  @@index([tenantId])
}

// ============ JOURNAL ENTRIES ============

model JournalEntry {
  id             String             @id @default(cuid())
  entryNumber    Int
  date           DateTime
  description    String
  reference      String?
  status         JournalEntryStatus @default(DRAFT)
  fiscalPeriodId String
  fiscalPeriod   FiscalPeriod       @relation(fields: [fiscalPeriodId], references: [id])
  reversalOfId   String?            @unique
  reversalOf     JournalEntry?      @relation("Reversal", fields: [reversalOfId], references: [id])
  reversedBy     JournalEntry?      @relation("Reversal")
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  createdById    String
  createdAt      DateTime           @default(now())
  postedAt       DateTime?

  lines JournalLine[]

  @@index([tenantId, date])
  @@index([tenantId, entryNumber])
  @@index([tenantId, status])
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0) @db.Decimal(18, 4)
  credit         Decimal      @default(0) @db.Decimal(18, 4)
  description    String?
  metadata       Json?

  @@index([journalEntryId])
  @@index([accountId])
}

// ============ E-INVOICE & TAX ============

enum TaxCountry {
  EG  // Egypt - ETA
  SA  // Saudi Arabia - ZATCA
}

enum InvoiceType {
  SALES        // فاتورة مبيعات
  SALES_RETURN // مردودات مبيعات
  PURCHASE     // فاتورة مشتريات
  DEBIT_NOTE   // إشعار مدين
  CREDIT_NOTE  // إشعار دائن
}

enum InvoiceStatus {
  DRAFT        // مسودة
  READY        // جاهز للإرسال
  SUBMITTED    // تم الإرسال
  ACCEPTED     // مقبولة
  REJECTED     // مرفوضة
  CANCELLED    // ملغاة
}

enum SubmissionStatus {
  PENDING
  SUCCESS
  FAILED
  RETRY
}

// Tax configuration per tenant
model TaxConfig {
  id                String     @id @default(cuid())
  tenantId          String     @unique
  tenant            Tenant     @relation(fields: [tenantId], references: [id])
  country           TaxCountry

  // Common fields
  taxRegistrationNumber String    // الرقم الضريبي
  companyNameAr      String       // اسم الشركة بالعربي
  companyNameEn      String?      // اسم الشركة بالإنجليزي
  branchId           String?      // رمز الفرع
  activityCode       String?      // كود النشاط

  // Address
  addressStreet      String?
  addressCity        String?
  addressState       String?
  addressCountry     String?
  addressPostalCode  String?
  addressBuildingNo  String?
  addressAdditionalNo String?     // SA: Additional number
  addressDistrict    String?      // SA: District

  // Egypt ETA specific
  etaClientId        String?      // ETA Client ID
  etaClientSecret    String?      // ETA Client Secret
  etaSignerSerialNo  String?      // رقم شهادة التوقيع الإلكتروني
  etaSignerPin       String?      // PIN التوقيع
  etaEnvironment     String?      @default("preproduction") // preproduction | production
  etaTokenEndpoint   String?
  etaApiEndpoint     String?

  // Saudi ZATCA specific
  zatcaCsid          String?      // Cryptographic Stamp Identifier
  zatcaPrivateKey    String?      // المفتاح الخاص
  zatcaCertificate   String?      // الشهادة
  zatcaSecretKey     String?      // Secret key
  zatcaEnvironment   String?      @default("sandbox") // sandbox | simulation | production
  zatcaOtp           String?      // OTP for onboarding

  // VAT config
  vatRate            Decimal      @default(0) @db.Decimal(5, 2)  // نسبة الضريبة الأساسية

  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// E-Invoice
model Invoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        // رقم الفاتورة
  internalId        String?       // Internal reference
  uuid              String?       // UUID for ZATCA / Document UUID for ETA
  type              InvoiceType
  status            InvoiceStatus @default(DRAFT)

  // Dates
  issueDate         DateTime
  supplyDate        DateTime?     // تاريخ التوريد

  // Buyer info
  buyerName         String
  buyerNameEn       String?
  buyerTaxId        String?       // الرقم الضريبي للمشتري
  buyerAddress      String?
  buyerCity         String?
  buyerCountry      String?      @default("EG")
  buyerType         String?      @default("B") // B=Business, P=Person, F=Foreign

  // Totals
  subtotal          Decimal       @db.Decimal(18, 4)  // المجموع قبل الضريبة
  totalVat          Decimal       @db.Decimal(18, 4)  // إجمالي الضريبة
  totalWithholding  Decimal       @default(0) @db.Decimal(18, 4) // ضريبة الخصم من المنبع (EG)
  totalTableTax     Decimal       @default(0) @db.Decimal(18, 4) // ضريبة الجدول (EG)
  totalDiscount     Decimal       @default(0) @db.Decimal(18, 4) // إجمالي الخصم
  grandTotal        Decimal       @db.Decimal(18, 4)  // الإجمالي النهائي
  currency          String        @default("EGP")
  exchangeRate      Decimal       @default(1) @db.Decimal(10, 4)

  // E-Invoice submission
  submissionUuid    String?       // ETA submission UUID / ZATCA clearance ID
  longId            String?       // ETA long ID
  hashKey           String?       // ZATCA invoice hash
  qrCode            String?       // QR code data
  signedXml         String?       // Signed XML content @db.Text
  pdfUrl            String?       // PDF/A-3 URL

  // Metadata
  notes             String?

  // Relations
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  journalEntryId    String?
  createdById       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customerId        String?
  customer          Customer?     @relation(fields: [customerId], references: [id])

  items             InvoiceItem[]
  submissions       InvoiceSubmission[]
  payments          Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([tenantId, issueDate])
  @@index([tenantId, buyerTaxId])
}

// Invoice line items
model InvoiceItem {
  id                String    @id @default(cuid())
  invoiceId         String
  invoice           Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  lineNumber        Int
  description       String
  descriptionEn     String?

  // Coding
  itemCode          String?   // ETA: EGS/GS1 code | ZATCA: item code
  itemCodeType      String?   // EGS, GS1, ZATCA
  internalCode      String?   // الكود الداخلي
  unitType          String?   @default("EA") // EA, KG, M, HR, etc.

  // Amounts
  quantity          Decimal   @db.Decimal(18, 4)
  unitPrice         Decimal   @db.Decimal(18, 4)
  discount          Decimal   @default(0) @db.Decimal(18, 4)
  discountRate      Decimal   @default(0) @db.Decimal(5, 2)

  // Tax
  vatRate           Decimal   @db.Decimal(5, 2)   // نسبة ض.ق.م
  vatAmount         Decimal   @db.Decimal(18, 4)  // مبلغ ض.ق.م
  vatCategory       String?   @default("S")       // S=Standard, Z=Zero, E=Exempt, O=Out of scope

  // Egypt specific taxes
  withholdingRate   Decimal   @default(0) @db.Decimal(5, 2)  // نسبة ضريبة الخصم من المنبع
  withholdingAmount Decimal   @default(0) @db.Decimal(18, 4)
  tableTaxRate      Decimal   @default(0) @db.Decimal(5, 2)  // نسبة ضريبة الجدول
  tableTaxAmount    Decimal   @default(0) @db.Decimal(18, 4)

  // Totals
  netAmount         Decimal   @db.Decimal(18, 4)  // الصافي بعد الخصم
  totalAmount       Decimal   @db.Decimal(18, 4)  // الإجمالي مع الضريبة

  // Linked account
  accountId         String?

  @@index([invoiceId])
}

// Submission log - tracks each attempt to submit to tax authority
model InvoiceSubmission {
  id                String           @id @default(cuid())
  invoiceId         String
  invoice           Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  country           TaxCountry
  status            SubmissionStatus @default(PENDING)

  // Request/Response
  requestPayload    String?          // JSON/XML sent
  responsePayload   String?          // Response from authority
  responseCode      String?          // HTTP status or error code
  errorMessage      String?          // Error details

  // Authority references
  submissionUuid    String?          // Authority submission ID
  documentUuid     String?          // Document UUID from authority
  longId            String?          // ETA long ID

  attemptNumber     Int              @default(1)
  submittedAt       DateTime         @default(now())

  @@index([invoiceId])
  @@index([status])
}

// ============ SUPER ADMIN ============

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============ CUSTOMERS (AR MODULE) ============

model Customer {
  id            String   @id @default(cuid())
  code          String
  nameAr        String
  nameEn        String?
  taxId         String?
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?  @default("SA")
  creditLimit   Decimal  @default(0) @db.Decimal(18, 4)
  paymentTerms  Int      @default(30) // days
  isActive      Boolean  @default(true)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  accountId     String?  // linked AR account
  invoices      Invoice[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ============ VENDORS (AP MODULE) ============

model Vendor {
  id            String   @id @default(cuid())
  code          String
  nameAr        String
  nameEn        String?
  taxId         String?
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?  @default("SA")
  paymentTerms  Int      @default(30)
  isActive      Boolean  @default(true)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  accountId     String?  // linked AP account
  bills         Bill[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ============ BILLS (AP MODULE) ============

enum BillStatus {
  DRAFT
  APPROVED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model Bill {
  id            String     @id @default(cuid())
  billNumber    String
  vendorId      String
  vendor        Vendor     @relation(fields: [vendorId], references: [id])
  issueDate     DateTime
  dueDate       DateTime
  status        BillStatus @default(DRAFT)
  subtotal      Decimal    @db.Decimal(18, 4)
  totalVat      Decimal    @default(0) @db.Decimal(18, 4)
  totalDiscount Decimal    @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal    @db.Decimal(18, 4)
  amountPaid    Decimal    @default(0) @db.Decimal(18, 4)
  currency      String     @default("SAR")
  notes         String?
  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  journalEntryId String?
  createdById   String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  items         BillItem[]
  payments      Payment[]

  @@unique([tenantId, billNumber])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
}

model BillItem {
  id          String  @id @default(cuid())
  billId      String
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  lineNumber  Int
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 4)
  discount    Decimal @default(0) @db.Decimal(18, 4)
  vatRate     Decimal @default(0) @db.Decimal(5, 2)
  vatAmount   Decimal @default(0) @db.Decimal(18, 4)
  netAmount   Decimal @db.Decimal(18, 4)
  totalAmount Decimal @db.Decimal(18, 4)
  accountId   String?

  @@index([billId])
}

// ============ PAYMENTS (SHARED AR/AP) ============

enum PaymentType {
  RECEIVED    // from customer (AR)
  MADE        // to vendor (AP)
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CREDIT_CARD
  OTHER
}

model Payment {
  id             String        @id @default(cuid())
  paymentNumber  String
  type           PaymentType
  method         PaymentMethod @default(BANK_TRANSFER)
  date           DateTime
  amount         Decimal       @db.Decimal(18, 4)
  currency       String        @default("SAR")
  reference      String?
  notes          String?
  // Links
  invoiceId      String?
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  billId         String?
  bill           Bill?         @relation(fields: [billId], references: [id])
  bankAccountId  String?
  bankAccount    BankAccount?  @relation(fields: [bankAccountId], references: [id])
  journalEntryId String?
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  createdById    String
  createdAt      DateTime      @default(now())

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, type])
  @@index([tenantId, date])
}

// ============ EMPLOYEES & PAYROLL (HR MODULE) ============

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

model Employee {
  id             String         @id @default(cuid())
  employeeNumber String
  nameAr         String
  nameEn         String?
  email          String?
  phone          String?
  nationalId     String?
  department     String?
  position       String?
  hireDate       DateTime
  terminationDate DateTime?
  status         EmployeeStatus @default(ACTIVE)
  // Salary
  basicSalary    Decimal        @db.Decimal(18, 4)
  housingAllowance Decimal      @default(0) @db.Decimal(18, 4)
  transportAllowance Decimal    @default(0) @db.Decimal(18, 4)
  otherAllowances Decimal       @default(0) @db.Decimal(18, 4)
  // Bank
  bankName       String?
  bankAccountNo  String?
  iban           String?

  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  payrollItems   PayrollItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([tenantId, employeeNumber])
  @@index([tenantId, status])
}

model Payroll {
  id             String   @id @default(cuid())
  period         String   // e.g. "2026-03"
  month          Int
  year           Int
  status         String   @default("DRAFT") // DRAFT, APPROVED, PAID
  totalBasic     Decimal  @default(0) @db.Decimal(18, 4)
  totalAllowances Decimal @default(0) @db.Decimal(18, 4)
  totalDeductions Decimal @default(0) @db.Decimal(18, 4)
  totalNet       Decimal  @default(0) @db.Decimal(18, 4)
  totalGosi      Decimal  @default(0) @db.Decimal(18, 4) // social insurance
  journalEntryId String?
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          PayrollItem[]

  @@unique([tenantId, period])
  @@index([tenantId])
}

model PayrollItem {
  id             String   @id @default(cuid())
  payrollId      String
  payroll        Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  basicSalary    Decimal  @db.Decimal(18, 4)
  housingAllowance Decimal @default(0) @db.Decimal(18, 4)
  transportAllowance Decimal @default(0) @db.Decimal(18, 4)
  otherAllowances Decimal @default(0) @db.Decimal(18, 4)
  totalEarnings  Decimal  @db.Decimal(18, 4)
  gosiEmployee   Decimal  @default(0) @db.Decimal(18, 4) // 9.75%
  gosiEmployer   Decimal  @default(0) @db.Decimal(18, 4) // 11.75%
  otherDeductions Decimal @default(0) @db.Decimal(18, 4)
  totalDeductions Decimal @db.Decimal(18, 4)
  netSalary      Decimal  @db.Decimal(18, 4)

  @@index([payrollId])
  @@index([employeeId])
}

// ============ BANK & CASH MODULE ============

enum BankAccountType {
  CHECKING
  SAVINGS
  CASH
  CREDIT_CARD_ACCOUNT
}

model BankAccount {
  id            String          @id @default(cuid())
  name          String
  bankName      String?
  accountNumber String?
  iban          String?
  type          BankAccountType @default(CHECKING)
  currency      String          @default("SAR")
  openingBalance Decimal        @default(0) @db.Decimal(18, 4)
  currentBalance Decimal        @default(0) @db.Decimal(18, 4)
  isActive      Boolean         @default(true)
  accountId     String?         // linked GL account
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  transactions  BankTransaction[]
  payments      Payment[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([tenantId, accountNumber])
  @@index([tenantId])
}

enum BankTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  FEE
  INTEREST
}

model BankTransaction {
  id             String              @id @default(cuid())
  bankAccountId  String
  bankAccount    BankAccount         @relation(fields: [bankAccountId], references: [id])
  type           BankTransactionType
  date           DateTime
  amount         Decimal             @db.Decimal(18, 4)
  balance        Decimal             @db.Decimal(18, 4) // running balance
  reference      String?
  description    String
  isReconciled   Boolean             @default(false)
  journalEntryId String?
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  createdAt      DateTime            @default(now())

  @@index([bankAccountId, date])
  @@index([tenantId])
}

// ============ SUBSCRIPTION & USAGE ============

enum PlanType {
  FREE_TRIAL
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

model Subscription {
  id              String             @id @default(cuid())
  tenantId        String             @unique
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  plan            PlanType           @default(FREE_TRIAL)
  status          SubscriptionStatus @default(ACTIVE)

  // Trial
  trialStartDate  DateTime           @default(now())
  trialEndDate    DateTime           // trial end = start + 365 days (1 year)

  // Storage limits (in bytes)
  storageLimit    BigInt             @default(102400000) // 100,000 KB free trial
  storageUsed     BigInt             @default(0)

  // Feature limits
  maxUsers        Int                @default(3)
  maxInvoices     Int                @default(100) // per month
  invoicesThisMonth Int              @default(0)

  // Billing
  pricePerGbUsd   Decimal            @default(8) @db.Decimal(10, 2) // $8 per GB
  monthlyPriceUsd Decimal            @default(0) @db.Decimal(10, 2)
  lastBillingDate DateTime?
  nextBillingDate DateTime?

  // Warnings sent
  warning50Sent   Boolean            @default(false)
  warning80Sent   Boolean            @default(false)
  warning95Sent   Boolean            @default(false)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

// ============ INVENTORY MODULE ============

model Product {
  id              String   @id @default(cuid())
  code            String
  nameAr          String
  nameEn          String?
  description     String?
  barcode         String?
  category        String?
  unitType        String   @default("EA") // EA, KG, MTR, LTR, etc.

  // Pricing
  costPrice       Decimal  @default(0) @db.Decimal(18, 4)
  sellingPrice    Decimal  @default(0) @db.Decimal(18, 4)

  // Stock
  currentStock    Decimal  @default(0) @db.Decimal(18, 4)
  minimumStock    Decimal  @default(0) @db.Decimal(18, 4)
  maximumStock    Decimal  @default(0) @db.Decimal(18, 4)
  reorderLevel    Decimal  @default(0) @db.Decimal(18, 4)

  // Tracking
  trackExpiry     Boolean  @default(false)
  trackBatch      Boolean  @default(false)

  // VAT
  vatRate         Decimal  @default(0) @db.Decimal(5, 2)
  vatCategory     String?  @default("S") // S=Standard, Z=Zero, E=Exempt

  // Linked GL account
  inventoryAccountId  String?  // حساب المخزون
  cogsAccountId       String?  // حساب تكلفة البضاعة المباعة
  revenueAccountId    String?  // حساب الإيراد

  isActive        Boolean  @default(true)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  stockMovements  StockMovement[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, category])
}

enum StockMovementType {
  IN           // وارد
  OUT          // صادر
  ADJUSTMENT   // تسوية
  TRANSFER     // تحويل
  RETURN_IN    // مرتجع وارد
  RETURN_OUT   // مرتجع صادر
  OPENING      // رصيد افتتاحي
}

model StockMovement {
  id              String            @id @default(cuid())
  movementNumber  String
  type            StockMovementType
  date            DateTime

  productId       String
  product         Product           @relation(fields: [productId], references: [id])

  quantity        Decimal           @db.Decimal(18, 4)
  unitCost        Decimal           @default(0) @db.Decimal(18, 4)
  totalCost       Decimal           @default(0) @db.Decimal(18, 4)

  // Batch / Expiry tracking
  batchNumber     String?
  expiryDate      DateTime?

  // Warehouse
  warehouseFrom   String?
  warehouseTo     String?

  reference       String?  // invoice number, bill number, etc.
  notes           String?

  journalEntryId  String?
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  createdById     String
  createdAt       DateTime @default(now())

  @@unique([tenantId, movementNumber])
  @@index([tenantId, productId])
  @@index([tenantId, date])
  @@index([tenantId, type])
}

// ============ FIXED ASSETS MODULE ============

enum AssetStatus {
  ACTIVE
  FULLY_DEPRECIATED
  DISPOSED
  UNDER_MAINTENANCE
}

enum DepreciationMethod {
  STRAIGHT_LINE     // القسط الثابت
  DECLINING_BALANCE // القسط المتناقص
  UNITS_OF_PRODUCTION // وحدات الإنتاج
}

model FixedAsset {
  id                  String              @id @default(cuid())
  assetNumber         String
  nameAr              String
  nameEn              String?
  description         String?
  category            String?             // أثاث، معدات، سيارات، مباني
  location            String?
  serialNumber        String?

  // Acquisition
  acquisitionDate     DateTime
  acquisitionCost     Decimal             @db.Decimal(18, 4)
  residualValue       Decimal             @default(0) @db.Decimal(18, 4)
  usefulLifeMonths    Int                 // العمر الإنتاجي بالأشهر

  // Depreciation
  depreciationMethod  DepreciationMethod  @default(STRAIGHT_LINE)
  monthlyDepreciation Decimal             @default(0) @db.Decimal(18, 4)
  accumulatedDepreciation Decimal         @default(0) @db.Decimal(18, 4)
  netBookValue        Decimal             @default(0) @db.Decimal(18, 4)
  lastDepreciationDate DateTime?

  // Status
  status              AssetStatus         @default(ACTIVE)
  disposalDate        DateTime?
  disposalPrice       Decimal?            @db.Decimal(18, 4)
  disposalGainLoss    Decimal?            @db.Decimal(18, 4)

  // GL Accounts
  assetAccountId      String?             // حساب الأصل
  depreciationAccountId String?           // حساب مصروف الإهلاك
  accDepreciationAccountId String?        // حساب مجمع الإهلاك

  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id])

  depreciationEntries DepreciationEntry[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([tenantId, assetNumber])
  @@index([tenantId, status])
  @@index([tenantId, category])
}

model DepreciationEntry {
  id              String     @id @default(cuid())
  assetId         String
  asset           FixedAsset @relation(fields: [assetId], references: [id])

  period          String     // "2026-03"
  date            DateTime
  amount          Decimal    @db.Decimal(18, 4)
  accumulatedTotal Decimal   @db.Decimal(18, 4)
  netBookValue    Decimal    @db.Decimal(18, 4)

  journalEntryId  String?
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  createdAt       DateTime   @default(now())

  @@index([assetId])
  @@index([tenantId, period])
}
